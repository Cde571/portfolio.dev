<!-- Reemplaza el <script is:inline> con este <script> normal -->

<script define:vars={{ backHash, musicVideoId, clickSfx, musicSrc }}>
  const initPixelConsoles = () => {
    console.log("🎮 [PixelConsole] Init started");
    
    const consoles = Array.from(document.querySelectorAll("[data-console]"));
    console.log("🎮 [PixelConsole] Found consoles:", consoles.length);
    
    if (!consoles.length) {
      console.warn("❌ [PixelConsole] No consoles found!");
      return;
    }

    consoles.forEach((root, consoleIndex) => {
      console.log(`🎮 [Console ${consoleIndex}] Initializing...`);
      
      // Evitar doble init
      if (root.dataset.pcInit === "true") {
        console.log(`⚠️ [Console ${consoleIndex}] Already initialized, skipping`);
        return;
      }
      root.dataset.pcInit = "true";

      // Variables desde Astro props
      const videoId = musicVideoId;
      const hashBack = backHash;
      
      console.log(`📋 [Console ${consoleIndex}] Config:`, { hashBack, videoId });

      // Query selectors más robustos
      const wrap = root.closest(".pc-wrap");
      console.log(`🔍 [Console ${consoleIndex}] Wrap found:`, !!wrap);

      const items = Array.from(root.querySelectorAll(".pc-menu-item"));
      const bubble = root.querySelector("[data-bubble] .pc-bubble-text");
      const click = (wrap || document).querySelector("audio[data-click]");
      const music = (wrap || document).querySelector("audio[data-music]");
      const modal = (wrap || document).querySelector("[data-music-modal]");
      const modalClose = (wrap || document).querySelector("[data-music-close]");
      const iframe = (wrap || document).querySelector("[data-music-iframe]");

      console.log(`🔍 [Console ${consoleIndex}] Elements:`, {
        items: items.length,
        bubble: !!bubble,
        click: !!click,
        music: !!music,
        modal: !!modal,
        modalClose: !!modalClose,
        iframe: !!iframe
      });

      let index = 0;
      let musicOn = false;
      let armed = false;

      // ========== FUNCIONES ==========
      
      const playClick = () => {
        console.log("🔊 [Sound] Playing click");
        if (!click) {
          console.warn("⚠️ [Sound] Click audio not found!");
          return;
        }
        try {
          click.currentTime = 0;
          click.play().catch(e => console.error("❌ [Sound] Play failed:", e));
        } catch (e) {
          console.error("❌ [Sound] Error:", e);
        }
      };

      const shake = () => {
        console.log("📳 [FX] Shake effect");
        root.classList.add("pc-shake");
        setTimeout(() => root.classList.remove("pc-shake"), 220);
      };

      const setActive = (i) => {
        if (!items.length) {
          console.warn("⚠️ [Menu] No items found!");
          return;
        }
        
        index = (i + items.length) % items.length;
        console.log(`📍 [Menu] Active index: ${index}`);

        items.forEach((btn, idx) => {
          const active = idx === index;
          btn.dataset.active = active ? "true" : "false";
          btn.setAttribute("aria-selected", active ? "true" : "false");
          const caret = btn.querySelector(".pc-caret");
          if (caret) caret.textContent = active ? ">" : "";
        });

        const label = items[index]?.querySelector(".pc-label")?.textContent?.trim() ?? "";
        console.log(`🏷️ [Menu] Selected: "${label}"`);
        if (bubble) bubble.textContent = `Select: ${label}`;
      };

      const pressFX = (el) => {
        if (!el) return;
        console.log("🎯 [FX] Button press effect");
        el.dataset.pressed = "true";
        setTimeout(() => { delete el.dataset.pressed; }, 150);
      };

      const openVideo = () => {
        console.log("🎬 [Video] Opening modal");
        if (!modal || !iframe) {
          console.warn("⚠️ [Video] Modal or iframe not found!");
          return;
        }
        iframe.src = `https://www.youtube-nocookie.com/embed/${videoId}?autoplay=1&rel=0`;
        if (typeof modal.showModal === "function") {
          modal.showModal();
        } else {
          modal.setAttribute("open", "true");
        }
        if (bubble) bubble.textContent = "Playing video...";
      };

      const closeVideo = () => {
        console.log("⏹️ [Video] Closing modal");
        if (!modal || !iframe) return;
        iframe.src = "";
        if (typeof modal.close === "function") {
          modal.close();
        } else {
          modal.removeAttribute("open");
        }
        if (bubble) bubble.textContent = "Video closed";
      };

      const doScrollHash = (hash) => {
        console.log(`📜 [Navigation] Scrolling to: ${hash}`);
        const target = document.querySelector(hash);
        if (target) {
          target.scrollIntoView({ behavior: "smooth", block: "start" });
        } else {
          console.warn(`⚠️ [Navigation] Target not found: ${hash}`);
        }
        history.replaceState(null, "", hash);
      };

      const activate = () => {
        console.log("✅ [Action] Activate triggered");
        const btn = items[index];
        if (!btn) {
          console.warn("⚠️ [Action] No button at current index!");
          return;
        }

        playClick();
        shake();

        const aBtn = root.querySelector('[data-btn="a"]');
        if (aBtn) pressFX(aBtn);

        const action = btn.dataset.action || "";
        console.log(`🎯 [Action] Executing: "${action}"`);

        window.dispatchEvent(new CustomEvent("pixelconsole:select", {
          detail: { index, label: btn.textContent.trim(), action }
        }));

        if (action.startsWith("#")) {
          doScrollHash(action);
          return;
        }

        if (action === "music:video") {
          openVideo();
          return;
        }

        if (action === "music:toggle") {
          if (!music) {
            console.warn("⚠️ [Music] Audio element not found!");
            return;
          }
          try {
            if (!musicOn) {
              music.volume = 0.6;
              music.loop = true;
              music.play().catch(e => console.error("❌ [Music] Play failed:", e));
              musicOn = true;
              if (bubble) bubble.textContent = "Music: ON";
              console.log("🎵 [Music] Started");
            } else {
              music.pause();
              musicOn = false;
              if (bubble) bubble.textContent = "Music: OFF";
              console.log("⏸️ [Music] Paused");
            }
          } catch (e) {
            console.error("❌ [Music] Error:", e);
          }
          return;
        }

        if (action.startsWith("/")) {
          console.log(`🔗 [Link] Opening: ${action}`);
          window.open(action, "_blank", "noopener,noreferrer");
          return;
        }
      };

      const back = () => {
        console.log("⬅️ [Action] Back triggered");
        
        if (modal && modal.open) {
          playClick();
          closeVideo();
          return;
        }

        playClick();
        shake();

        const bBtn = root.querySelector('[data-btn="b"]');
        if (bBtn) pressFX(bBtn);

        window.dispatchEvent(new CustomEvent("pixelconsole:back"));
        if (hashBack && hashBack.startsWith("#")) doScrollHash(hashBack);
      };

      const move = (dir) => {
        console.log(`🎮 [Move] Direction: ${dir}`);
        playClick();
        if (dir === "up" || dir === "left") setActive(index - 1);
        if (dir === "down" || dir === "right") setActive(index + 1);
      };

      // ========== ARMADO DE TECLADO ==========
      
      const arm = () => {
        if (!armed) {
          console.log("🔓 [Keyboard] Armed!");
          armed = true;
        }
        try { 
          root.focus({ preventScroll: true }); 
        } catch { 
          root.focus(); 
        }
      };

      const disarmIfOutside = (e) => {
        if (!root.contains(e.target) && armed) {
          console.log("🔒 [Keyboard] Disarmed");
          armed = false;
        }
      };

      root.addEventListener("pointerdown", () => {
        console.log("👆 [Event] Console clicked");
        arm();
      });
      
      root.addEventListener("focusin", () => {
        console.log("🎯 [Event] Console focused");
        arm();
      });
      
      document.addEventListener("pointerdown", disarmIfOutside);

      // ========== CLICK EN MENÚ ==========
      
      items.forEach((btn, btnIndex) => {
        btn.addEventListener("click", (e) => {
          console.log(`🖱️ [Menu Item ${btnIndex}] Clicked`);
          arm();
          const i = Number(btn.dataset.index || "0");
          setActive(i);
          activate();
        });
      });

      // ========== D-PAD ==========
      
      const dpadButtons = root.querySelectorAll("[data-dpad]");
      console.log(`🕹️ [D-pad] Found ${dpadButtons.length} buttons`);
      
      dpadButtons.forEach((b) => {
        const dir = b.getAttribute("data-dpad");
        b.addEventListener("click", () => {
          console.log(`🕹️ [D-pad] ${dir} clicked`);
          arm();
          pressFX(b);
          if (dir === "mid") return;
          move(dir);
        });
      });

      // ========== BOTONES A/B/START/SELECT ==========
      
      const controlButtons = root.querySelectorAll("[data-btn]");
      console.log(`🎮 [Buttons] Found ${controlButtons.length} control buttons`);
      
      controlButtons.forEach((b) => {
        const key = b.getAttribute("data-btn");
        b.addEventListener("click", () => {
          console.log(`🎮 [Button] ${key.toUpperCase()} clicked`);
          arm();
          pressFX(b);
          if (key === "a" || key === "start") activate();
          if (key === "b" || key === "select") back();
        });
      });

      // ========== MODAL ==========
      
      if (modalClose) {
        modalClose.addEventListener("click", () => {
          console.log("❌ [Modal] Close button clicked");
          closeVideo();
        });
      }
      
      if (modal) {
        modal.addEventListener("close", () => {
          console.log("🔒 [Modal] Closed event");
          if (iframe) iframe.src = "";
        });
        
        modal.addEventListener("click", (e) => {
          if (e.target === modal) {
            console.log("🖱️ [Modal] Backdrop clicked");
            closeVideo();
          }
        });
      }

      // ========== TECLADO ==========
      
      window.addEventListener("keydown", (e) => {
        // ESC siempre cierra video
        if (modal && modal.open && e.key === "Escape") {
          console.log("⌨️ [Keyboard] ESC - closing video");
          e.preventDefault();
          closeVideo();
          return;
        }

        if (!armed) {
          return;
        }

        const k = e.key;
        console.log(`⌨️ [Keyboard] Key: ${k}`);
        
        if (k === "ArrowUp")    { e.preventDefault(); move("up"); return; }
        if (k === "ArrowDown")  { e.preventDefault(); move("down"); return; }
        if (k === "ArrowLeft")  { e.preventDefault(); move("left"); return; }
        if (k === "ArrowRight") { e.preventDefault(); move("right"); return; }
        if (k === "Enter")      { e.preventDefault(); activate(); return; }
        if (k === "Escape" || k === "Backspace") { e.preventDefault(); back(); return; }
      }, { passive: false });

      // ========== ESTADO INICIAL ==========
      
      console.log(`✅ [Console ${consoleIndex}] Initialized successfully`);
      setActive(0);
    });
    
    console.log("🎮 [PixelConsole] All consoles initialized");
  };

  // ========== INICIALIZACIÓN ==========
  
  if (document.readyState === "loading") {
    console.log("⏳ [Init] Waiting for DOMContentLoaded...");
    document.addEventListener("DOMContentLoaded", initPixelConsoles);
  } else {
    console.log("✅ [Init] DOM already loaded, initializing now");
    initPixelConsoles();
  }
  
  document.addEventListener("astro:page-load", () => {
    console.log("🔄 [Astro] Page load event");
    initPixelConsoles();
  });
</script>
