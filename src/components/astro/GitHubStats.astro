<!-- ============================================
     GITHUB STATISTICS - LAYOUT COMPACTO OPTIMIZADO
     ============================================ -->
<section class="github-compact" id="github" aria-label="GitHub Snapshot">
  <div class="github-header" data-reveal>
    <h2 class="github-title">GitHub Snapshot</h2>
    <p class="github-subtitle">Public repositories, profile activity and technology focus</p>
  </div>

  <!-- Stats Grid Compacto (2 columnas) -->
  <div class="stats-compact-grid">
    <!-- Columna Izquierda: Stats Numéricos -->
    <div class="stats-column">
      <div class="stat-compact" data-reveal>
        <div class="stat-icon">
          <i data-feather="package" aria-hidden="true"></i>
        </div>
        <div class="stat-info">
          <div class="stat-number">54</div>
          <div class="stat-label">Public Repositories</div>
        </div>
      </div>

      <div class="stat-compact" data-reveal>
        <div class="stat-icon">
          <i data-feather="git-commit" aria-hidden="true"></i>
        </div>
        <div class="stat-info">
          <div class="stat-number">7</div>
          <div class="stat-label">Followers</div>
        </div>
      </div>

      <div class="stat-compact" data-reveal>
        <div class="stat-icon">
          <i data-feather="star" aria-hidden="true"></i>
        </div>
        <div class="stat-info">
          <div class="stat-number">4</div>
          <div class="stat-label">Stars</div>
        </div>
      </div>

      <div class="stat-compact" data-reveal>
        <div class="stat-icon">
          <i data-feather="users" aria-hidden="true"></i>
        </div>
        <div class="stat-info">
          <div class="stat-number">36</div>
          <div class="stat-label">Following</div>
        </div>
      </div>
    </div>

    <!-- Columna Derecha: Lenguajes -->
    <div class="languages-compact" data-reveal>
      <div class="languages-header">
        <i data-feather="code" aria-hidden="true"></i>
        <span>Repo Languages</span>
      </div>
      
      <div class="language-list">
        <div class="lang-item">
          <div class="lang-bar-wrapper">
            <div class="lang-bar typescript" style="width: 74%"></div>
          </div>
          <div class="lang-meta">
            <span class="lang-name">
              <span class="lang-dot typescript"></span>
              TypeScript
            </span>
            <span class="lang-percent">Frontend</span>
          </div>
        </div>

        <div class="lang-item">
          <div class="lang-bar-wrapper">
            <div class="lang-bar python" style="width: 16%"></div>
          </div>
          <div class="lang-meta">
            <span class="lang-name">
              <span class="lang-dot python"></span>
              Python
            </span>
            <span class="lang-percent">AI/Data</span>
          </div>
        </div>

        <div class="lang-item">
          <div class="lang-bar-wrapper">
            <div class="lang-bar javascript" style="width: 5%"></div>
          </div>
          <div class="lang-meta">
            <span class="lang-name">
              <span class="lang-dot javascript"></span>
              JavaScript
            </span>
            <span class="lang-percent">Backend</span>
          </div>
        </div>

        <div class="lang-item">
          <div class="lang-bar-wrapper">
            <div class="lang-bar other" style="width: 5%"></div>
          </div>
          <div class="lang-meta">
            <span class="lang-name">
              <span class="lang-dot other"></span>
              Other
            </span>
            <span class="lang-percent">Systems</span>
          </div>
        </div>
      </div>

      <!-- Activity indicator -->
      <div class="activity-indicator">
        <span class="activity-dot"></span>
        <span class="activity-text">Active public profile</span>
      </div>
    </div>
  </div>

