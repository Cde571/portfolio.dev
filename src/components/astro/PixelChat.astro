<div class="pixel-chat-widget" id="pixelChatWidget" aria-live="polite">
  <!-- Bot (asoma desde la izquierda) -->
  <button class="pixel-bot" id="pixelBotToggle" type="button" aria-label="Open chat">
    <span class="pixel-bot-face" aria-hidden="true">
      <span class="pixel-bot-eye"></span>
      <span class="pixel-bot-eye"></span>
    </span>
  </button>

  <!-- Bubble -->
  <div class="pixel-bubble" id="pixelBubble" role="dialog" aria-label="Chat prompt">
    <p class="pixel-bubble-text">Psst... Would you like to chat personally?</p>

    <div class="pixel-bubble-actions">
      <a class="pixel-btn pixel-btn-primary" id="pixelChatBtn" href="#contact">
        <span class="pixel-btn-ico" aria-hidden="true">✈</span>
        CHAT
      </a>

      <button class="pixel-btn pixel-btn-close" id="pixelChatClose" type="button" aria-label="Close">
        ×
      </button>
    </div>

    <!-- Tail (bocadillo) -->
    <span class="pixel-bubble-tail" aria-hidden="true"></span>
  </div>
</div>
