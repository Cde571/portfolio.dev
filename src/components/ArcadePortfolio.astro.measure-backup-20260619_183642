        const distance = Math.abs(center - target);
        const power = clamp(1 - distance / (vh * 0.82), 0, 1);
        const side = index % 2 === 0 ? -1 : 1;
        const before = center < target;
        const x = side * (1 - power) * (before ? -38 : 82);
        const y = (1 - power) * (before ? -18 : 46);
        const opacity = clamp(0.45 + power * 0.55, 0.45, 1);
        const blur = (1 - power) * 1.4;
        const scale = 0.975 + power * 0.025;

        section.style.setProperty('--section-x', `${x.toFixed(2)}px`);
        section.style.setProperty('--section-y', `${y.toFixed(2)}px`);
        section.style.setProperty('--section-opacity', opacity.toFixed(3));
        section.style.setProperty('--section-blur', `${blur.toFixed(2)}px`);
        section.style.setProperty('--section-scale', scale.toFixed(4));

        if (distance < activeScore) {
          activeScore = distance;
          activeName = (section.id || section.className || 'SECTION').toString().replace(/[-_]/g, ' ').toUpperCase();
        }
      });

      if (stageLabel) stageLabel.textContent = activeName;
    }

    function updateCards() {
      const vh = window.innerHeight || 800;
      const target = vh * 0.58;
      let bestScore = Infinity;
      let bestCard = null;

      cards.forEach((card, index) => {
        if (card.classList.contains('is-hidden-by-filter')) {
          card.classList.remove('is-immersive-focus', 'is-immersive-left', 'is-immersive-right');
          return;
        }

        const rect = card.getBoundingClientRect();
        const center = rect.top + rect.height / 2;
        const distance = Math.abs(center - target);
        const focus = clamp(1 - distance / (vh * 0.58), 0, 1);
        const side = index % 2 === 0 ? -1 : 1;
        const past = center < target;
        const spread = 1 - focus;
        const x = side * spread * (past ? -64 : 118);
        const y = spread * (past ? -22 : 44);
        const rot = side * spread * (past ? -1.8 : 3.2);
        const scale = 0.965 + focus * 0.055;
        const opacity = clamp(0.50 + focus * 0.50, 0.50, 1);
        const brightness = 0.82 + focus * 0.28;
        const saturation = 0.92 + focus * 0.26;

        card.style.setProperty('--repo-x', `${x.toFixed(2)}px`);
        card.style.setProperty('--repo-y', `${y.toFixed(2)}px`);
        card.style.setProperty('--repo-rot', `${rot.toFixed(3)}deg`);
        card.style.setProperty('--repo-scale', scale.toFixed(4));
        card.style.setProperty('--repo-opacity', opacity.toFixed(3));
        card.style.setProperty('--repo-bright', brightness.toFixed(3));
        card.style.setProperty('--repo-sat', saturation.toFixed(3));
        card.style.setProperty('--repo-scan-opacity', (focus > 0.72 ? (focus - 0.72) * 2.7 : 0).toFixed(3));
        card.classList.toggle('is-immersive-focus', focus > 0.74);
        card.classList.toggle('is-immersive-left', side < 0);
        card.classList.toggle('is-immersive-right', side > 0);

        if (distance < bestScore) {
          bestScore = distance;
          bestCard = card;
        }
      });

      const projects = document.querySelector('.projects-section');
      if (projects && bestCard) {
        const rect = bestCard.getBoundingClientRect();
        const x = clamp(((rect.left + rect.width / 2) / Math.max(1, window.innerWidth)) * 100, 8, 92);
        const y = clamp(((rect.top + rect.height / 2) / Math.max(1, window.innerHeight)) * 100, 8, 92);
        projects.style.setProperty('--repo-spot-x', `${x.toFixed(2)}%`);
        projects.style.setProperty('--repo-spot-y', `${y.toFixed(2)}%`);
      }
    }

    function updateProgress() {
      const max = Math.max(1, document.documentElement.scrollHeight - window.innerHeight);
      const p = clamp(window.scrollY / max, 0, 1);
      document.documentElement.style.setProperty('--scroll-total', `${(p * 100).toFixed(2)}%`);
      lane.style.setProperty('--lane-dot-y', `${(p * 100).toFixed(2)}%`);
    }

    let ticking = false;
    function update() {
      ticking = false;
      updateProgress();
      updateHero();
      updateSections();
      updateCards();
    }

    function requestUpdate() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(update);
    }

    update();
    window.addEventListener('scroll', requestUpdate, { passive: true });
    window.addEventListener('resize', requestUpdate, { passive: true });
    document.addEventListener('input', requestUpdate, true);
    document.addEventListener('click', () => setTimeout(requestUpdate, 80), true);
  })();
</script>
