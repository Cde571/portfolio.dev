    /* GitHub Section */
    .github-section { position: relative; z-index: 1; padding: 5.5rem 2rem; }
    .github-header { max-width: 1400px; margin: 0 auto 2.25rem; }
    .github-title { font-size: clamp(1.8rem, 2.4vw, 2.6rem); margin-bottom: 0.5rem; }
