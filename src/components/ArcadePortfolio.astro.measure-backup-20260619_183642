    // =========================
    const GITHUB_REPOSITORIES = 54;
    const GITHUB_STARS = 4;
    const EXPERIENCE_START = new Date("2023-01-01");

    // =========================
    // Helpers
    // =========================
    function formatNumber(n) {
      try { return Number(n).toLocaleString(navigator.language || "es-CO"); }
      catch { return String(n); }
    }

    function countUp(el, to, suffix = "+", duration = 900) {
      if (!el) return;
      const from = 0;
      const start = performance.now();
      const t = Math.max(300, duration);

      function step(now) {
        const p = Math.min(1, (now - start) / t);
        const eased = 1 - Math.pow(1 - p, 3);
        const val = Math.floor(from + (to - from) * eased);
        el.textContent = `${formatNumber(val)}${suffix}`;
        if (p < 1) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
    }

    // =========================
    // Years / Projects dinámicos
    // =========================
    function computeYears() {
      const now = new Date();
      let years = now.getFullYear() - EXPERIENCE_START.getFullYear();
      const m = now.getMonth() - EXPERIENCE_START.getMonth();
      if (m < 0 || (m === 0 && now.getDate() < EXPERIENCE_START.getDate())) years--;
      return Math.max(0, years);
    }

    function computeProjects() {
      // cuenta tus cards actuales
      return document.querySelectorAll(".project-card").length || 0;
    }

