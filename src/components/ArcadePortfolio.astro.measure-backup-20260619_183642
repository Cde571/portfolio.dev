      font-family: var(--font-mono);
      color: rgba(255, 255, 255, 0.9);
      opacity: 0.96;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .project-info { padding: 1.25rem; }
    .project-info h3 { font-size: 1.1rem; margin-bottom: 0.4rem; }
    .project-info p {
      font-family: var(--font-sans);
      color: var(--text-secondary);
      line-height: 1.7;
      margin-bottom: 0.9rem;
    }

    .project-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; }
    .tag {
      padding: 0.35rem 0.6rem;
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, 0.12);
      background: rgba(0, 0, 0, 0.22);
      color: rgba(255, 255, 255, 0.85);
      font-size: 0.78rem;
      font-weight: 800;
    }

    /* About */
    .about-section { position: relative; z-index: 1; padding: 5.5rem 2rem; }
    .about-content {
      max-width: 1400px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1.25fr 0.75fr;
      gap: 3rem;
      align-items: start;
    }
    .section-label {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      font-family: var(--font-mono);
      font-size: 0.8rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--text-secondary);
      margin-bottom: 1rem;
    }
    .section-label svg { width: 16px; height: 16px; }

    .about-title { font-size: clamp(2rem, 2.8vw, 3rem); line-height: 1.15; margin-bottom: 1.25rem; }

    .about-divider { display: flex; gap: 0.5rem; margin: 1.25rem 0 1.75rem; }
    .divider-line { width: 34px; height: 3px; border-radius: 999px; background: rgba(255,255,255,0.18); }
    .divider-line:nth-child(2) { background: rgba(255,255,255,0.28); }
    .divider-line:nth-child(3) { background: var(--accent); }

    .about-description {
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid var(--border);
