/* =========================================================
   REPO SCROLL CINEMATIC PATCH
   Efecto scroll atractivo para las 54 tarjetas sin cambiar la IU.
   ========================================================= */
.projects-section {
  position: relative;
  --repo-spotlight-y: 50%;
}

.projects-section::before {
  content: "";
  position: absolute;
  left: 50%;
  top: var(--repo-spotlight-y, 50%);
  z-index: 0;
  width: min(760px, 88vw);
  height: 360px;
  transform: translate(-50%, -50%);
  background:
    radial-gradient(circle at 42% 50%, rgba(0,245,255,0.12), transparent 34%),
    radial-gradient(circle at 60% 55%, rgba(255,43,214,0.10), transparent 42%);
  filter: blur(26px);
  pointer-events: none;
  opacity: 0.78;
}

.projects-section > * {
  position: relative;
  z-index: 1;
}

.projects-grid {
  counter-reset: repo-card;
  perspective: 1300px;
  transform-style: preserve-3d;
}

.projects-grid .project-card {
  counter-increment: repo-card;
  --repo-scroll-lift: 0px;
  --repo-tilt-x: 0deg;
  --repo-tilt-y: 0deg;
  --repo-scale: 0.985;
  --repo-glow: 0;
  --repo-rail: rgba(0,245,255,0.45);
  transform-origin: 50% 50%;
  will-change: transform, filter, opacity;
  background:
    linear-gradient(180deg, rgba(255,255,255,0.045), rgba(255,255,255,0.022)),
    rgba(255, 255, 255, 0.03);
}

.projects-grid .project-card[data-reveal],
.projects-grid .project-card[data-reveal].is-visible,
.projects-grid .project-card:hover,
.projects-grid .project-card.is-scroll-focus {
  transform:
    translate3d(0, calc(var(--repo-scroll-lift, 0px) - var(--repo-hover-lift, 0px)), 0)
    rotateX(var(--repo-tilt-x, 0deg))
    rotateY(var(--repo-tilt-y, 0deg))
    scale(var(--repo-scale, 1));
}

.projects-grid .project-card:hover,
.projects-grid .project-card.is-scroll-focus {
  --repo-hover-lift: 6px;
  border-color: color-mix(in srgb, var(--repo-rail) 65%, rgba(255,255,255,0.24));
  box-shadow:
    0 26px 72px rgba(0,0,0,0.45),
    0 0 calc(12px + var(--repo-glow, 0) * 28px) color-mix(in srgb, var(--repo-rail) 35%, transparent),
    0 0 0 1px rgba(255,255,255,0.05) inset;
}

.projects-grid .project-card::after {
  content: "#" counter(repo-card, decimal-leading-zero);
  position: absolute;
  top: 0.78rem;
  right: 0.78rem;
  z-index: 5;
  padding: 0.28rem 0.45rem;
  border: 1px solid color-mix(in srgb, var(--repo-rail) 42%, rgba(255,255,255,0.12));
  border-radius: 999px;
  background: rgba(0,0,0,0.58);
  color: color-mix(in srgb, var(--repo-rail) 75%, white);
  font-family: var(--font-mono);
  font-size: 0.62rem;
  letter-spacing: 0.08em;
  opacity: calc(0.45 + var(--repo-glow, 0) * 0.5);
  box-shadow: 0 0 16px color-mix(in srgb, var(--repo-rail) 24%, transparent);
  transform: translateZ(38px);
  pointer-events: none;
}

.projects-grid .project-card::before {
  background:
    radial-gradient(circle at var(--mx, 50%) var(--my, 0%), color-mix(in srgb, var(--repo-rail) 34%, transparent), transparent 32%),
    linear-gradient(135deg, rgba(255,43,214,0.12), transparent 35%, rgba(140,255,0,0.10)),
    linear-gradient(90deg, color-mix(in srgb, var(--repo-rail) 38%, transparent), transparent 18%);
  opacity: calc(var(--repo-glow, 0) * 0.78);
}

.projects-grid .project-image {
  transform: translateZ(24px);
  border-bottom-color: color-mix(in srgb, var(--repo-rail) 22%, rgba(255,255,255,0.08));
}

.projects-grid .project-image::after {
  background:
    linear-gradient(180deg, rgba(0,0,0,0.03), rgba(0,0,0,0.55)),
    linear-gradient(90deg, transparent 0 46%, color-mix(in srgb, var(--repo-rail) 25%, transparent) 50%, transparent 54%),
    repeating-linear-gradient(0deg, rgba(255,255,255,0.052) 0 1px, transparent 1px 5px);
  background-position: 0 0, 0 var(--repo-scan-y, 0%), 0 0;
}

.projects-grid .project-cover {
  transform:
    scale(calc(1.02 + var(--repo-glow, 0) * 0.055))
    translate3d(0, var(--cover-shift, 0px), 0);
  filter:
    saturate(calc(1.05 + var(--repo-glow, 0) * 0.35))
    contrast(calc(1.02 + var(--repo-glow, 0) * 0.12));
}

.projects-grid .project-card:hover .project-cover,
.projects-grid .project-card.is-scroll-focus .project-cover {
  transform:
    scale(calc(1.08 + var(--repo-glow, 0) * 0.035))
    translate3d(0, var(--cover-shift, 0px), 0);
}

.projects-grid .project-info {
  position: relative;
  transform: translateZ(20px);
}

.projects-grid .project-info::before {
  content: "";
  position: absolute;
  left: 0.82rem;
  top: 0;
  bottom: 1rem;
  width: 2px;
  border-radius: 999px;
  background: linear-gradient(180deg, transparent, var(--repo-rail), transparent);
  opacity: calc(0.12 + var(--repo-glow, 0) * 0.58);
  box-shadow: 0 0 14px var(--repo-rail);
}

.projects-grid .repo-meta,
.projects-grid .project-info h3,
.projects-grid .project-info p,
.projects-grid .project-tags,
.projects-grid .project-actions {
  margin-left: 0.35rem;
}

.projects-grid .project-info h3 {
  text-shadow: 0 0 calc(4px + var(--repo-glow, 0) * 12px) color-mix(in srgb, var(--repo-rail) 42%, transparent);
}

.projects-grid .project-actions .project-link {
  transition: transform 0.2s ease, border-color 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
}

.projects-grid .project-actions .project-link:hover {
  transform: translateY(-2px);
  border-color: color-mix(in srgb, var(--repo-rail) 62%, rgba(255,255,255,0.20));
  background: color-mix(in srgb, var(--repo-rail) 16%, rgba(0,0,0,0.28));
  box-shadow: 0 0 18px color-mix(in srgb, var(--repo-rail) 20%, transparent);
}

.projects-grid .project-card.is-scroll-past {
  filter: saturate(0.9) brightness(0.86);
}

.projects-grid .project-card.is-scroll-next {
  filter: saturate(1.08) brightness(1.04);
}

@media (max-width: 768px) {
  .projects-grid .project-card[data-reveal],
  .projects-grid .project-card[data-reveal].is-visible,
  .projects-grid .project-card:hover,
  .projects-grid .project-card.is-scroll-focus {
    transform: translateY(var(--repo-scroll-lift, 0px)) scale(var(--repo-scale, 1));
  }
}

@media (prefers-reduced-motion: reduce) {
  .projects-grid .project-card,
  .projects-grid .project-card[data-reveal],
  .projects-grid .project-card[data-reveal].is-visible,
  .projects-grid .project-card:hover,
  .projects-grid .project-card.is-scroll-focus {
    transform: none !important;
  }
  .projects-section::before {
    display: none;
  }
}
