    .ascii-face { font-family: var(--font-mono); font-size: 1.25rem; color: rgba(255,255,255,0.85); }

    .profile-name { font-size: 1.25rem; margin-top: 0.35rem; display: inline-flex; gap: 0.5rem; align-items: center; }
