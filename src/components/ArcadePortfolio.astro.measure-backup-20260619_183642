(function () {
  const cards = Array.from(document.querySelectorAll('[data-project-card]'));
  const section = document.querySelector('.projects-section');
  if (!cards.length || !section) return;
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const rails = ['rgba(0,245,255,0.72)', 'rgba(255,43,214,0.72)', 'rgba(140,255,0,0.72)', 'rgba(255,230,109,0.72)', 'rgba(124,92,255,0.72)', 'rgba(255,122,0,0.72)'];

  cards.forEach((card, index) => {
    card.style.setProperty('--repo-rail', rails[index % rails.length]);
    card.style.setProperty('--repo-scale', '0.985');
  });

  function clamp(value, min, max) {
    return Math.max(min, Math.min(max, value));
  }

  let ticking = false;
  function update() {
    ticking = false;
    const vh = window.innerHeight || 800;
    const viewportCenter = vh * 0.52;
    const sectionRect = section.getBoundingClientRect();
    const sectionProgress = clamp((vh - sectionRect.top) / (vh + sectionRect.height), 0, 1);
    section.style.setProperty('--repo-spotlight-y', `${(sectionProgress * 100).toFixed(2)}%`);

    cards.forEach((card) => {
      if (card.classList.contains('is-hidden-by-filter')) return;
      const rect = card.getBoundingClientRect();
      const center = rect.top + rect.height / 2;
      const delta = clamp((center - viewportCenter) / (vh * 0.55), -1.35, 1.35);
      const focus = clamp(1 - Math.abs(delta), 0, 1);
      const direction = delta < 0 ? -1 : 1;

      card.classList.toggle('is-scroll-focus', focus > 0.62);
      card.classList.toggle('is-scroll-past', delta < -0.92);
      card.classList.toggle('is-scroll-next', delta > 0.38 && delta < 1.05);

      if (reduceMotion) {
        card.style.setProperty('--repo-glow', '0');
        card.style.setProperty('--repo-scroll-lift', '0px');
        card.style.setProperty('--cover-shift', '0px');
        return;
      }

      card.style.setProperty('--repo-glow', focus.toFixed(3));
      card.style.setProperty('--repo-scroll-lift', `${(-12 * focus).toFixed(2)}px`);
      card.style.setProperty('--repo-scale', (0.968 + focus * 0.045).toFixed(3));
      card.style.setProperty('--repo-tilt-x', `${(-delta * 5.8).toFixed(2)}deg`);
      card.style.setProperty('--repo-tilt-y', `${(direction * focus * 1.65).toFixed(2)}deg`);
      card.style.setProperty('--cover-shift', `${(-18 * focus + delta * 7).toFixed(2)}px`);
      card.style.setProperty('--repo-scan-y', `${(focus * 120).toFixed(2)}%`);
    });
  }

  function requestUpdate() {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(update);
  }

  update();
  window.addEventListener('scroll', requestUpdate, { passive: true });
  window.addEventListener('resize', requestUpdate, { passive: true });
  document.addEventListener('input', requestUpdate, true);
  document.addEventListener('click', requestUpdate, true);
})();
