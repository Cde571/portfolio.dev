      padding: 0.45rem 0.65rem;
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, 0.12);
      background: rgba(255, 255, 255, 0.03);
      color: rgba(255, 255, 255, 0.85);
      font-size: 0.85rem;
      font-weight: 900;
      font-family: var(--font-sans);
