 /* Pixel Character — pure CSS */
  .pixel-char{
    width: 380px;
    height: 200px;
    display: grid;
    place-items: center;
    position: relative;
    image-rendering: pixelated;
    transform: translateZ(0);
    filter: drop-shadow(0 12px 22px rgba(0,0,0,.35));
  }

  /* Shared pixel look */
  .pixel-char *{
    box-sizing: border-box;
    image-rendering: pixelated;
  }

  /* HEAD */
  .pixel-head{
    width: 120px;
    height: 100px;
    position: relative;
    border: 6px solid rgba(255,255,255,.18);
    border-radius: 14px;
    background:
      linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,.04));
    box-shadow:
      inset 0 0 0 6px rgba(0,0,0,.25),
      0 10px 0 rgba(0,0,0,.18);
    transform-origin: 50% 80%;
    animation: pixelIdle 2.8s ease-in-out infinite;
  }

  .pixel-eye{
    width: 16px;
    height: 16px;
    position: absolute;
    top: 34px;
    border-radius: 3px;
    background: rgba(255,255,255,.85);
    box-shadow:
      inset 0 -3px 0 rgba(0,0,0,.35),
      0 0 0 6px rgba(255,255,255,.07);
  }
  .pixel-eye.left{ left: 28px; }
  .pixel-eye.right{ right: 28px; }

  .pixel-mouth{
    position: absolute;
    left: 50%;
    top: 66px;
    width: 34px;
    height: 10px;
    transform: translateX(-50%);
    border-radius: 2px;
    background: rgba(0,0,0,.55);
    box-shadow: inset 0 3px 0 rgba(255,255,255,.10);
  }

  /* BODY */
  .pixel-body{
    width: 140px;
    height: 72px;
    margin-top: 10px;
    position: relative;
    display: grid;
    place-items: center;
  }

  .pixel-torso{
    width: 96px;
    height: 72px;
    border: 6px solid rgba(255,255,255,.16);
    border-radius: 16px;
    background:
      radial-gradient(circle at 30% 20%, rgba(59,130,246,.20), transparent 55%),
      linear-gradient(180deg, rgba(255,255,255,.08), rgba(255,255,255,.03));
    box-shadow: inset 0 0 0 6px rgba(0,0,0,.25);
    animation: pixelBreathe 2.8s ease-in-out infinite;
  }

  .pixel-arm{
    width: 22px;
    height: 54px;
    position: absolute;
    top: 10px;
    border: 6px solid rgba(255,255,255,.14);
    border-radius: 14px;
    background: rgba(255,255,255,.05);
    box-shadow: inset 0 0 0 6px rgba(0,0,0,.22);
    transform-origin: 50% 10%;
  }
  .pixel-arm.left{ left: 4px; animation: armSwingL 1.9s ease-in-out infinite; }
  .pixel-arm.right{ right: 4px; animation: armSwingR 1.9s ease-in-out infinite; }

  /* LEGS */
  .pixel-legs{
    width: 100px;
    height: 60px;
    margin-top: 8px;
    position: relative;
    display: flex;
    justify-content: space-between;
    padding: 0 18px;
  }

  .pixel-leg{
    width: 26px;
    height: 60px;
    border: 6px solid rgba(255,255,255,.14);
    border-radius: 14px;
    background: rgba(255,255,255,.04);
    box-shadow: inset 0 0 0 6px rgba(0,0,0,.22);
    transform-origin: 50% 10%;
  }
  .pixel-leg.left{ animation: legStepL 1.6s ease-in-out infinite; }
  .pixel-leg.right{ animation: legStepR 1.6s ease-in-out infinite; }

  /* Idle animations */
  @keyframes pixelIdle{
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-4px) rotate(-1deg); }
  }
  @keyframes pixelBreathe{
    0%, 100% { transform: scaleY(1); }
    50% { transform: scaleY(1.04); }
  }
  @keyframes armSwingL{
    0%, 100% { transform: rotate(10deg); }
    50% { transform: rotate(-12deg); }
  }
  @keyframes armSwingR{
    0%, 100% { transform: rotate(-10deg); }
    50% { transform: rotate(12deg); }
  }
  @keyframes legStepL{
    0%, 100% { transform: rotate(-6deg); }
    50% { transform: rotate(10deg); }
  }
  @keyframes legStepR{
    0%, 100% { transform: rotate(6deg); }
    50% { transform: rotate(-10deg); }
  }

  /* Optional: click reaction */
  .pixel-char:active .pixel-head{
    transform: translateY(-6px) rotate(2deg);
  }

  /* Small screens */
  @media (max-width: 480px){
    .pixel-char{ transform: scale(.9); }
  }
   .avatar-ring{
    width: clamp(170px, 22vw, 240px);
    height: clamp(170px, 22vw, 240px);
