    .tab-btn:hover { background: rgba(255, 255, 255, 0.06); color: var(--text-primary); transform: translateY(-1px); }
    .tab-btn.active { background: rgba(59, 130, 246, 0.15); border-color: rgba(59, 130, 246, 0.35); color: var(--text-primary); }
    .tab-btn svg { width: 16px; height: 16px; }

    .github-content { max-width: 1400px; margin: 0 auto; }

    .github-grid {
      display: grid;
      grid-template-columns: 1fr 0.9fr 1fr;
      gap: 1.25rem;
      align-items: stretch;
    }

    .github-stat-card {
      border-radius: 18px;
      border: 1px solid var(--border);
      background: rgba(255, 255, 255, 0.03);
      padding: 1.4rem;
      backdrop-filter: none;
      transition: transform 0.2s ease, border-color 0.2s ease;
    }
    .github-stat-card:hover { transform: translateY(-2px); border-color: rgba(255, 255, 255, 0.18); }

    .stat-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.9rem; }
    .stat-title { font-family: var(--font-mono); color: var(--text-secondary); letter-spacing: 0.16em; font-size: 0.75rem; }
    .stat-header svg { width: 16px; height: 16px; opacity: 0.65; }

    .stat-value { font-size: 2rem; font-weight: 900; }
    .stat-change { font-size: 0.9rem; color: var(--text-secondary); margin-left: 0.5rem; font-family: var(--font-sans); font-weight: 800; }
    .stat-change.positive { color: var(--green); }

    .github-robot {
      border-radius: 18px;
      border: 1px solid rgba(255, 255, 255, 0.12);
      background:
        radial-gradient(circle at 30% 20%, rgba(59, 130, 246, 0.18), transparent 55%),
        rgba(255, 255, 255, 0.02);
