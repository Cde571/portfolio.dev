(function () {
  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  // Ajusta velocidad global (px por segundo). Más bajo = más lento
  const SPEED_PX_PER_SEC = 18;

  function setupMarquee(marqueeEl) {
    const inner = marqueeEl.querySelector(".marquee-inner");
    if (!inner) return;

    // Si ya fue inicializado, no repetir
    if (marqueeEl.dataset.marqueeInit === "1") return;
    marqueeEl.dataset.marqueeInit = "1";

    // Necesitamos un grupo base para clonar
    const firstGroup = inner.querySelector(".marquee-group");
    if (!firstGroup) return;

    // Limpieza: dejar solo el primer group y borrar duplicados previos
    Array.from(inner.querySelectorAll(".marquee-group")).forEach((g, idx) => {
      if (idx !== 0) g.remove();
    });

    // Clonar grupos hasta que el ancho de la pista supere 2x el contenedor
    function fill() {
      // Quitar clones antiguos
      Array.from(inner.querySelectorAll(".marquee-group")).forEach((g, idx) => {
        if (idx !== 0) g.remove();
      });

      const containerWidth = marqueeEl.clientWidth || 1;
      let trackWidth = firstGroup.scrollWidth;

      // Clonar hasta cubrir al menos 2x el contenedor (para loop perfecto)
      while (trackWidth < containerWidth * 2) {
        const clone = firstGroup.cloneNode(true);
        clone.setAttribute("aria-hidden", "true");
        inner.appendChild(clone);
        trackWidth += firstGroup.scrollWidth;
      }

      // Calcular duración: distancia / velocidad
      // distancia ideal: ancho de un group (para volver al inicio sin salto)
      const distance = firstGroup.scrollWidth;
      const duration = Math.max(30, distance / SPEED_PX_PER_SEC); // mínimo 30s
      marqueeEl.style.setProperty("--duration", `${duration}s`);

      // Guardar distancia para CSS (si quieres usarla)
      marqueeEl.style.setProperty("--distance", `${distance}px`);
    }

    fill();

    // Recalcular en resize (debounced)
    let t = null;
    window.addEventListener("resize", () => {
      clearTimeout(t);
      t = setTimeout(fill, 150);
    });

    // Pausar con hover (opcional). Si NO quieres pausa, elimina esto:
    marqueeEl.addEventListener("mouseenter", () => marqueeEl.classList.add("is-hover"));
    marqueeEl.addEventListener("mouseleave", () => marqueeEl.classList.remove("is-hover"));

    // Hover glow (iluminar ítem sobre el que pasas el mouse)
    marqueeEl.addEventListener("pointerover", (e) => {
      const item = e.target.closest(".tech-logo");
      if (!item || !marqueeEl.contains(item)) return;

      // Apaga todos, prende el actual
      marqueeEl.querySelectorAll(".tech-logo").forEach((el) => el.classList.remove("is-active"));
      item.classList.add("is-active");
    });

    marqueeEl.addEventListener("pointerout", (e) => {
      const leavingTo = e.relatedTarget;
      // Si salimos del marquee completo, apagamos todo
      if (!leavingTo || !marqueeEl.contains(leavingTo)) {
        marqueeEl.querySelectorAll(".tech-logo").forEach((el) => el.classList.remove("is-active"));
      }
