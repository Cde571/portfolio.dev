(() => {
    const char = document.querySelector('.pixel-char');
    if (!char) return;

    const eyes = char.querySelectorAll('.pixel-eye');
    const MAX = 3; // px

    function clamp(n, min, max){ return Math.max(min, Math.min(max, n)); }

    function look(x, y){
      const r = char.getBoundingClientRect();
      const nx = ((x - r.left) / r.width) * 2 - 1;
      const ny = ((y - r.top) / r.height) * 2 - 1;
      const dx = clamp(nx, -1, 1) * MAX;
      const dy = clamp(ny, -1, 1) * MAX;

      eyes.forEach(e => {
