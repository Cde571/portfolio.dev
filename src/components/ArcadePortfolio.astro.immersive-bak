      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
    }
    .tab-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.55rem;
      padding: 0.7rem 0.9rem;
      border-radius: 999px;
      border: 1px solid var(--border);
