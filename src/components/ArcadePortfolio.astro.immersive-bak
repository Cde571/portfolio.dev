        const group = new THREE.Group();
        group.position.x = 1.35;
        scene.add(group);

        const colors = [0x00f5ff, 0xff2bd6, 0x8cff00, 0xffe66d];
        for (let i = 0; i < 6; i++) {
          const geo = new THREE.TorusGeometry(1.25 + i * 0.18, 0.008 + i * 0.002, 12, 128);
          const mat = new THREE.MeshBasicMaterial({
            color: colors[i % colors.length],
            transparent: true,
            opacity: 0.34 - i * 0.032,
            blending: THREE.AdditiveBlending,
            depthWrite: false,
          });
          const ring = new THREE.Mesh(geo, mat);
          ring.rotation.x = 1.25 + i * 0.09;
          ring.rotation.y = 0.45 - i * 0.06;
          ring.userData.spin = (i % 2 ? -1 : 1) * (0.0022 + i * 0.0008);
          group.add(ring);
        }

        const particleCount = 520;
        const pos = new Float32Array(particleCount * 3);
        const col = new Float32Array(particleCount * 3);
        const color = new THREE.Color();
        for (let i = 0; i < particleCount; i++) {
          const r = 0.2 + Math.random() * 2.6;
          const a = Math.random() * Math.PI * 2;
          const z = -8 + Math.random() * 12;
          pos[i * 3] = Math.cos(a) * r;
          pos[i * 3 + 1] = Math.sin(a) * r;
          pos[i * 3 + 2] = z;
          color.setHex(colors[i % colors.length]);
          col[i * 3] = color.r;
          col[i * 3 + 1] = color.g;
          col[i * 3 + 2] = color.b;
        }
        const pGeo = new THREE.BufferGeometry();
        pGeo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
        pGeo.setAttribute('color', new THREE.BufferAttribute(col, 3));
        const pMat = new THREE.PointsMaterial({
          size: 0.026,
          transparent: true,
          opacity: 0.82,
          vertexColors: true,
          blending: THREE.AdditiveBlending,
          depthWrite: false,
        });
        const points = new THREE.Points(pGeo, pMat);
        group.add(points);

        function resize() {
          const rect = hero.getBoundingClientRect();
          const w = Math.max(1, rect.width);
          const h = Math.max(1, rect.height);
          renderer.setSize(w, h, false);
          camera.aspect = w / h;
          camera.updateProjectionMatrix();
        }

        let raf = 0;
        function animate() {
          raf = requestAnimationFrame(animate);
          const progress = updateHeroPortalVars();
          const t = performance.now() * 0.001;

          group.rotation.z = t * 0.08 + progress * 1.8;
          group.rotation.y = Math.sin(t * 0.55) * 0.08 + progress * 0.42;
          group.scale.setScalar(0.9 + progress * 0.18);
          camera.position.z = 5.2 - progress * 1.45;
          camera.position.x = progress * 0.22;

          group.children.forEach((child) => {
            if (child.userData && child.userData.spin) child.rotation.z += child.userData.spin + progress * 0.006;
          });

          const attr = pGeo.getAttribute('position');
          for (let i = 0; i < particleCount; i++) {
            let z = attr.getZ(i) + 0.012 + progress * 0.05;
