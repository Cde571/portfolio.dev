    function initFeaturedRepoScreen() {
      const feature = document.querySelector('[data-repo-feature]');
      const cards = Array.from(document.querySelectorAll('[data-project-card]'));
      if (!feature || !cards.length) return;

      const image = feature.querySelector('[data-feature-image]');
      const imageLink = feature.querySelector('[data-feature-link]');
      const button = feature.querySelector('[data-feature-button]');
      const title = feature.querySelector('[data-feature-title]');
      const desc = feature.querySelector('[data-feature-description]');
      const language = feature.querySelector('[data-feature-language]');
      const category = feature.querySelector('[data-feature-category]');
      const updated = feature.querySelector('[data-feature-updated]');
      const counter = feature.querySelector('[data-feature-counter]');

