          const progress = updateHeroPortalVars();
          const w = canvas.clientWidth;
          const h = canvas.clientHeight;
          ctx.clearRect(0, 0, w, h);
          const cx = w * 0.78;
          const cy = h * 0.5;
          const base = Math.min(w, h) * (0.18 + progress * 0.05);
          for (let i = 0; i < 9; i++) {
            ctx.strokeStyle = ['rgba(0,255,255,.5)','rgba(255,0,255,.38)','rgba(140,255,0,.30)'][i % 3];
            ctx.lineWidth = 1 + i * 0.12;
            ctx.beginPath();
            ctx.ellipse(cx, cy, base + i * 18, base * 0.62 + i * 10, performance.now() * 0.0004 + i, 0, Math.PI * 2);
            ctx.stroke();
          }
