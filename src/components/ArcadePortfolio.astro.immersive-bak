  font-weight: 900;
  font-size: 0.9rem;
}

.activity-indicator {
  margin-top: 1.25rem;
  padding-top: 1rem;
  border-top: 1px solid rgba(255, 255, 255, 0.08);
  display: flex;
  align-items: center;
  gap: 0.6rem;
  font-size: 0.85rem;
  color: var(--text-secondary);
  font-family: var(--font-sans);
  font-weight: 700;
