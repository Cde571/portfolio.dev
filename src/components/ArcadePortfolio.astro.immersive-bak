      rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.22);
    box-shadow:
      0 18px 55px rgba(0,0,0,0.45),
      inset 0 0 0 1px rgba(255,255,255,0.08);
  }

  .avatar{
    width: 100%;
    height: 100%;
    border-radius: 999px;
    overflow: hidden; /* CLAVE */
    position: relative;
    display: grid;
    place-items: center;

    /* Variables para ajustar fácil */
    --posy: 28%;   /* baja/sube el encuadre */
    --zoom: 1.55;  /* agranda/achica el sujeto */
  }

  /* Recomendado para TU imagen (blanco + ilustración): look “sticker” */
  .avatar--sticker{
    background: #fff;
    border: 1px solid rgba(0,0,0,0.10);
    box-shadow:
      0 12px 28px rgba(0,0,0,0.30),
      inset 0 0 0 1px rgba(255,255,255,0.65);
  }

  .profile-avatar-img{
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;                 /* recorta y llena el círculo */
    object-position: 50% var(--posy);  /* mueve el recorte */
    transform: scale(var(--zoom));     /* zoom para eliminar “márgenes blancos” */
    filter: contrast(1.08) saturate(1.02);
  }

  /* Micro borde interno para que se vea “pro” */
  .avatar::after{
    content:"";
    position:absolute;
    inset:0;
    border-radius: 999px;
    pointer-events:none;
    box-shadow:
      inset 0 0 0 1px rgba(255,255,255,0.12),
      inset 0 -18px 30px rgba(0,0,0,0.18);
  }

  /* Light theme */
  :root[data-theme="light"] .avatar-ring{
    border-color: rgba(10,10,10,0.14);
    box-shadow: 0 16px 45px rgba(0,0,0,0.18), inset 0 0 0 1px rgba(10,10,10,0.06);
  }

  /* Si se recorta demasiado, ajusta aquí sin tocar nada más:
     .avatar { --posy: 24%; --zoom: 1.45; }
