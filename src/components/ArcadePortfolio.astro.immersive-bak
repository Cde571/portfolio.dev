          image.style.opacity = '0.08';
          window.setTimeout(() => {
            image.src = info.image;
            image.alt = `Miniatura de ${info.title}`;
            image.style.opacity = '1';
          }, 90);
        }
        if (imageLink) imageLink.href = info.href;
        if (button) button.href = info.href;
        feature.style.setProperty('--feature-glow', String(0.48 + strength * 0.34));
      }

      function updateByScroll() {
        const vh = window.innerHeight || 800;
        const center = vh * 0.53;
        let bestCard = null;
        let bestIndex = 0;
        let bestScore = Infinity;
        cards.forEach((card, index) => {
          if (card.classList.contains('is-hidden-by-filter')) return;
          const rect = card.getBoundingClientRect();
          if (rect.bottom < 0 || rect.top > vh) return;
          const cardCenter = rect.top + rect.height / 2;
          const score = Math.abs(cardCenter - center);
          if (score < bestScore) {
            bestScore = score;
            bestCard = card;
            bestIndex = index;
          }
        });
        if (bestCard) {
          const strength = clamp(1 - bestScore / (vh * 0.55), 0, 1);
          setActive(bestCard, bestIndex, strength);
          const progress = clamp((vh - feature.getBoundingClientRect().top) / (vh + feature.offsetHeight), 0, 1);
