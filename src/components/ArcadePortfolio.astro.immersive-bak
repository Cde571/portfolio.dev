  /* ===============================
     PIXEL CHAT WIDGET — ESTILOS
  =============================== */
  .pixel-chat-widget{
    position: fixed;
    left: 18px;
    bottom: calc(18px + env(safe-area-inset-bottom, 0px));
    z-index: 1400;
    display: flex;
    align-items: flex-end;
    gap: 10px;
    pointer-events: none; /* se habilita solo en hijos */
  }

  .pixel-chat-widget * { box-sizing: border-box; }

  /* Bot */
  .pixel-bot{
    pointer-events: auto;
    width: 84px;
    height: 84px;
    border: 3px solid #111;
    background: #1b1b1b;
    border-radius: 12px;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    box-shadow: 6px 6px 0 rgba(0,0,0,0.28);
    transform: translateX(-28px) translateY(18px) rotate(-6deg);
    transition: transform 220ms ease, box-shadow 220ms ease;
  }

  .pixel-bot:hover{
    transform: translateX(-22px) translateY(14px) rotate(-5deg);
    box-shadow: 8px 10px 0 rgba(0,0,0,0.30);
  }

  .pixel-bot-face{
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    gap: 10px;
    align-content: center;
  }

  .pixel-bot-eye{
    width: 14px;
    height: 14px;
    background: #fff;
    border: 2px solid #111;
    border-radius: 4px;
    box-shadow:
      0 0 0 6px rgba(255,255,255,0.06),
      0 0 14px rgba(255,255,255,0.18);
  }
  .pixel-bot-eye:nth-child(1){ transform: translateX(-10px); }
  .pixel-bot-eye:nth-child(2){ transform: translateX(10px); }

  /* Bubble */
  .pixel-bubble{
    pointer-events: auto;
    width: min(360px, calc(100vw - 140px));
    background: #f7f7f7;
    color: #111;
    border: 3px solid #111;
    border-radius: 6px;
    padding: 14px 14px 12px;
    box-shadow: 6px 6px 0 rgba(0,0,0,0.28);
    position: relative;

    /* Estado hidden por defecto */
    opacity: 0;
    transform: translateY(18px) scale(0.98);
    transition: opacity 240ms ease, transform 240ms ease;
  }

  .pixel-bubble-text{
    margin: 0 0 12px;
    font-family: var(--font-pixel, system-ui);
    font-size: 12px;
    line-height: 1.4;
  }

  .pixel-bubble-actions{
    display: flex;
    gap: 10px;
    align-items: center;
  }

  .pixel-btn{
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    height: 42px;
    padding: 0 14px;
    border: 3px solid #111;
    border-radius: 6px;
    font-family: var(--font-pixel, system-ui);
    font-size: 12px;
    text-decoration: none;
    cursor: pointer;
    user-select: none;
    transition: transform 160ms ease, filter 160ms ease;
  }

  .pixel-btn:active{ transform: translateY(1px); }

  .pixel-btn-ico{
    font-size: 12px;
    line-height: 1;
    transform: translateY(-1px);
  }

  .pixel-btn-primary{
    flex: 1;
    background: #1e88e5;
    color: #fff;
  }
  .pixel-btn-primary:hover{ filter: brightness(1.05); }

  .pixel-btn-close{
    width: 48px;
    background: #e53935;
    color: #fff;
    padding: 0;
    font-size: 18px;
    line-height: 1;
  }
  .pixel-btn-close:hover{ filter: brightness(1.05); }

  /* Tail pixel */
  .pixel-bubble-tail{
    position: absolute;
    left: -14px;
    bottom: 18px;
    width: 14px;
    height: 18px;
    background: #f7f7f7;
    border-left: 3px solid #111;
    border-top: 3px solid #111;
    border-bottom: 3px solid #111;
    clip-path: polygon(100% 0, 0 50%, 100% 100%);
  }

  /* Visible state */
  .pixel-chat-widget.is-visible .pixel-bubble{
    opacity: 1;
    transform: translateY(0) scale(1);
  }
  .pixel-chat-widget.is-visible .pixel-bot{
    transform: translateX(-10px) translateY(0) rotate(-4deg);
  }

  /* Focus accesible */
  .pixel-bot:focus-visible,
  .pixel-btn:focus-visible{
    outline: 3px solid rgba(59,130,246,0.8);
    outline-offset: 3px;
  }

  /* Responsive */
  @media (max-width: 520px){
    .pixel-bot{ width: 74px; height: 74px; }
    .pixel-bubble{ width: min(320px, calc(100vw - 130px)); }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce){
    .pixel-bubble, .pixel-bot{ transition: none !important; }
  }
