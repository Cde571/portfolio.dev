            `rgba(160,255,0,${0.18 - k * 0.05})`,
          ][i % 3];
          ctx.lineWidth = 1 + (1 - k) * 1.4;
          ctx.setLineDash([16 + i * 2, 12 + i]);
          ctx.lineDashOffset = -t * 38 * (i % 2 ? -1 : 1) - p * 130;
          ctx.beginPath();
          ctx.ellipse(0, 0, radius, radius * 0.72, 0, 0, Math.PI * 2);
          ctx.stroke();
          ctx.restore();
        }

        // Lineas de velocidad
        for (const s of stars) {
          s.z -= 0.0022 * s.speed + p * 0.006;
          if (s.z <= 0.02) {
            s.z = 1;
            s.a = Math.random() * Math.PI * 2;
            s.r = 40 + Math.random() * 430;
          }
          const scale = 1 / s.z;
          const x = cx + Math.cos(s.a + t * 0.04) * s.r * scale * 0.23;
          const y = cy + Math.sin(s.a + t * 0.04) * s.r * scale * 0.13;
          const len = (1 - s.z) * 34 + p * 18;
          ctx.strokeStyle = `hsla(${s.hue}, 100%, 55%, ${0.10 + (1 - s.z) * 0.34})`;
          ctx.lineWidth = 1.1;
          ctx.beginPath();
          ctx.moveTo(x, y);
          ctx.lineTo(x + Math.cos(s.a) * len, y + Math.sin(s.a) * len * 0.55);
          ctx.stroke();
        }

        requestAnimationFrame(draw);
      }

      resize();
      draw();
      window.addEventListener('resize', resize, { passive: true });
      window.addEventListener('scroll', heroProgress, { passive: true });
    }

    function initRepoShowcaseEnhance() {
      const feature = document.querySelector('[data-repo-feature]');
      const cards = Array.from(document.querySelectorAll('[data-project-card]'));
      if (!feature || !cards.length) return;

      const fields = {
        image: feature.querySelector('[data-feature-image]'),
        link: feature.querySelector('[data-feature-link]'),
        button: feature.querySelector('[data-feature-button]'),
        title: feature.querySelector('[data-feature-title]'),
        desc: feature.querySelector('[data-feature-description]'),
        language: feature.querySelector('[data-feature-language]'),
        category: feature.querySelector('[data-feature-category]'),
        updated: feature.querySelector('[data-feature-updated]'),
        counter: feature.querySelector('[data-feature-counter]'),
      };

      let active = -1;
      function extract(card, index) {
        const img = card.querySelector('.project-cover');
        const meta = Array.from(card.querySelectorAll('.repo-meta span')).map((x) => x.textContent.trim()).filter(Boolean);
        const tags = Array.from(card.querySelectorAll('.tag')).map((x) => x.textContent.trim()).filter(Boolean);
        return {
          index,
          title: card.querySelector('h3')?.textContent?.trim() || `Repo ${index + 1}`,
          desc: card.querySelector('.project-info p')?.textContent?.trim() || 'Repositorio conectado a GitHub.',
          href: card.getAttribute('data-repo-href') || 'https://github.com/Cde571?tab=repositories',
          image: img?.getAttribute('src') || '/projects/covers/scroll-effects.png',
          language: meta[0] || tags[0] || 'Repo',
          updated: meta[1] || 'GitHub',
          category: tags[1] || tags[0] || 'Proyecto',
        };
      }

      function activate(card, index, intensity) {
        if (!card) return;
        if (index !== active) {
          active = index;
          const info = extract(card, index);
          cards.forEach((c) => c.classList.toggle('is-feature-active', c === card));
          if (fields.title) fields.title.textContent = info.title;
          if (fields.desc) fields.desc.textContent = info.desc;
          if (fields.language) fields.language.textContent = info.language;
          if (fields.category) fields.category.textContent = info.category;
          if (fields.updated) fields.updated.textContent = info.updated;
          if (fields.counter) fields.counter.textContent = `#${String(index + 1).padStart(2, '0')}`;
          if (fields.link) fields.link.href = info.href;
          if (fields.button) fields.button.href = info.href;
          if (fields.image) {
            fields.image.style.opacity = '0';
            window.setTimeout(() => {
              fields.image.src = info.image;
              fields.image.alt = `Miniatura de ${info.title}`;
              fields.image.style.opacity = '1';
            }, 80);
          }
        }
        feature.style.setProperty('--feature-intensity', intensity.toFixed(3));
        feature.style.setProperty('--feature-glow', (0.58 + intensity * 0.32).toFixed(3));
        feature.style.setProperty('--feature-scale', intensity.toFixed(3));
      }

      function update() {
        const vh = window.innerHeight || 800;
        const target = vh * 0.55;
        let best = null;
        let bestIndex = 0;
        let bestScore = Infinity;

        for (let i = 0; i < cards.length; i++) {
          const card = cards[i];
          if (card.classList.contains('is-hidden-by-filter')) continue;
          const rect = card.getBoundingClientRect();
          if (rect.bottom < 0 || rect.top > vh) continue;
          const center = rect.top + rect.height / 2;
          const score = Math.abs(center - target);
          const intensity = clamp(1 - score / (vh * 0.55), 0, 1);
          card.style.setProperty('--repo-scroll-lift', `${(-8 * intensity).toFixed(2)}px`);
          card.style.setProperty('--repo-tilt-x', `${(-2.2 * intensity).toFixed(3)}`);
          card.style.setProperty('--repo-tilt-y', `${(i % 2 ? -1.6 : 1.6) * intensity}`);
          card.classList.toggle('is-scroll-focus', intensity > 0.56);
          if (score < bestScore) {
            best = card;
            bestIndex = i;
            bestScore = score;
          }
        }

        if (best) {
          const intensity = clamp(1 - bestScore / (vh * 0.55), 0, 1);
          activate(best, bestIndex, intensity);
        }
      }

      let ticking = false;
      const requestUpdate = () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          ticking = false;
          update();
        });
      };

      cards.forEach((card, i) => {
        card.addEventListener('pointerenter', () => activate(card, i, 1));
        card.addEventListener('focus', () => activate(card, i, 1));
      });

      update();
      window.addEventListener('scroll', requestUpdate, { passive: true });
      window.addEventListener('resize', requestUpdate, { passive: true });
      document.addEventListener('input', requestUpdate, true);
      document.addEventListener('click', requestUpdate, true);
    }

    heroProgress();
    initCanvasTunnel();
    initRepoShowcaseEnhance();
  })();
</script>
