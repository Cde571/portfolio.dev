  mask-image: linear-gradient(to right, transparent, #000 8%, #000 92%, transparent);
}

.scroll-track {
  display: flex;
  width: max-content;
  gap: 1.5rem;
  animation: scrollInfinite var(--duration, 25s) linear infinite;
  will-change: transform;
}

.tech-scroll.reverse .scroll-track {
  animation-direction: reverse;
}

.tech-scroll[data-speed="slow"] { --duration: 35s; }
.tech-scroll[data-speed="medium"] { --duration: 28s; }
.tech-scroll[data-speed="fast"] { --duration: 22s; }

@keyframes scrollInfinite {
  from { transform: translateX(0); }
  to { transform: translateX(-50%); }
}

.scroll-group {
  display: flex;
  gap: 1.5rem;
  padding-right: 1.5rem;
}

.tech-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  min-width: 70px;
  padding: 0.75rem;
  border-radius: 12px;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.08);
  transition: all 0.25s ease;
  cursor: pointer;
}

.tech-item img {
  width: 32px;
  height: 32px;
  filter: grayscale(0.6) brightness(1.1);
  transition: filter 0.25s ease, transform 0.25s ease;
}

.tech-item span {
  font-size: 0.7rem;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.65);
  transition: color 0.25s ease;
  text-align: center;
  font-family: var(--font-sans);
}

/* Hover: pausa scroll y resalta ítem */
.tech-scroll:hover .scroll-track {
  animation-play-state: paused;
}

.tech-item:hover {
  background: rgba(255, 255, 255, 0.08);
  border-color: rgba(59, 130, 246, 0.4);
  transform: translateY(-3px) scale(1.05);
  box-shadow: 0 8px 24px rgba(59, 130, 246, 0.15);
}

.tech-item:hover img {
  filter: grayscale(0) brightness(1.2);
  transform: scale(1.1);
}

.tech-item:hover span {
  color: rgba(255, 255, 255, 0.95);
}

/* Controles opcionales */
.scroll-controls {
  margin-top: 1.25rem;
  display: flex;
  justify-content: center;
  gap: 0.75rem;
}

.control-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.6rem 1rem;
  border-radius: 999px;
  border: 1px solid rgba(255, 255, 255, 0.12);
  background: rgba(255, 255, 255, 0.03);
  color: var(--text-secondary);
  font-size: 0.85rem;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.2s ease;
  font-family: var(--font-sans);
}

.control-btn:hover {
  background: rgba(255, 255, 255, 0.06);
  border-color: rgba(255, 255, 255, 0.2);
  color: var(--text-primary);
}

.control-btn svg { width: 16px; height: 16px; }

/* ==========================================
   GITHUB STATS - LAYOUT COMPACTO
   ========================================== */

.github-compact {
  padding: 5.5rem 2rem;
  position: relative;
  z-index: 1;
}

.github-header {
  max-width: 1400px;
  margin: 0 auto 2rem;
}

.github-title {
  font-size: clamp(1.8rem, 2.4vw, 2.6rem);
