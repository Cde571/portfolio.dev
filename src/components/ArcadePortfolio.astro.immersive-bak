          index,
          title: card.querySelector('h3')?.textContent?.trim() || `Repositorio ${index + 1}`,
          desc: card.querySelector('.project-info p')?.textContent?.trim() || 'Proyecto conectado a GitHub.',
          href: card.getAttribute('data-repo-href') || '#',
          image: img?.getAttribute('src') || img?.src || '/projects/covers/scroll-effects.png',
          language: meta[0] || tags[0] || 'Repo',
          updated: meta[1] || 'GitHub',
          category: tags[2] || tags[1] || 'Proyecto',
        };
      };

      let activeIndex = -1;
      function setActive(card, index, strength = 1) {
        if (!card || index === activeIndex) return;
        activeIndex = index;
        cards.forEach((item) => item.classList.toggle('is-feature-active', item === card));
        const info = getInfo(card, index);
        if (title) title.textContent = info.title;
        if (desc) desc.textContent = info.desc;
        if (language) language.textContent = info.language;
        if (category) category.textContent = info.category;
        if (updated) updated.textContent = info.updated;
        if (counter) counter.textContent = `#${String(index + 1).padStart(2, '0')}`;
