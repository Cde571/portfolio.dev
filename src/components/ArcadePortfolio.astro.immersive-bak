  background: rgba(16, 185, 129, 0.15);
  color: var(--green);
  font-weight: 700;
}

.stat-label {
  font-size: 0.8rem;
  color: var(--text-secondary);
  font-weight: 600;
  margin-top: 0.25rem;
  font-family: var(--font-sans);
}

/* Languages Column */
.languages-compact {
