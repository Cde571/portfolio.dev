---
import Navigation from './astro/Navigation.astro';
import Hero from './astro/Hero.astro';
import Stats from './astro/Stats.astro';
import Projects from './astro/Projects.astro';
import About from './astro/About.astro';
import GitHubStats from './astro/GitHubStats.astro';
import Contact from './astro/Contact.astro';
import Experience from './astro/Experience.astro';
import PixelChat from './astro/PixelChat.astro';
import ScrollIndicator from './astro/ScrollIndicator.astro';
---

<div class="arcade-container">
  <canvas id="arcadeCanvas" aria-hidden="true"></canvas>

  <Navigation />
  <Hero />
  <Stats />
  <Projects />
  <About />
  <GitHubStats />
  <Contact />
  <Experience />
  <PixelChat />
  <ScrollIndicator />

  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/feather-icons/4.29.2/feather.min.js">

  // ==========================================
  // PROJECTS: filtros, card-click y scroll effects
  // ==========================================
  (function () {
    const cards = Array.from(document.querySelectorAll('[data-project-card]'));
    const search = document.getElementById('projectSearch');
    const filters = Array.from(document.querySelectorAll('.repo-filter'));
    const resultCount = document.getElementById('projectResultCount');
    if (!cards.length) return;

    cards.forEach((card, index) => {
      card.style.setProperty('--project-delay', `${Math.min(index * 28, 420)}ms`);

      card.addEventListener('click', (event) => {
        if (event.target.closest('[data-project-action]')) return;
        const href = card.getAttribute('data-repo-href');
        if (href) window.open(href, '_blank', 'noopener,noreferrer');
      });

      card.addEventListener('keydown', (event) => {
        if (event.key !== 'Enter') return;
        const href = card.getAttribute('data-repo-href');
        if (href) window.open(href, '_blank', 'noopener,noreferrer');
      });

      card.addEventListener('pointermove', (event) => {
        const rect = card.getBoundingClientRect();
        const mx = ((event.clientX - rect.left) / rect.width) * 100;
        const my = ((event.clientY - rect.top) / rect.height) * 100;
        card.style.setProperty('--mx', `${mx}%`);
        card.style.setProperty('--my', `${my}%`);
      });
    });

    let activeFilter = 'all';
    function normalize(value) {
      return (value || '').toString().toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
    }

    function applyFilters() {
      const q = normalize(search && search.value);
      let visible = 0;
      cards.forEach((card) => {
        const haystack = normalize(card.innerText);
        const matchesText = !q || haystack.includes(q);
        const matchesLang = activeFilter === 'all' || haystack.includes(normalize(activeFilter));
        const show = matchesText && matchesLang;
        card.classList.toggle('is-hidden-by-filter', !show);
        if (show) visible++;
      });
      if (resultCount) resultCount.textContent = `${visible} repositorios visibles`;
    }

    if (search) search.addEventListener('input', applyFilters);
    filters.forEach((btn) => {
      btn.addEventListener('click', () => {
        filters.forEach((b) => b.classList.remove('is-active'));
        btn.classList.add('is-active');
        activeFilter = btn.dataset.filter || 'all';
        applyFilters();
      });
    });

    function updateScrollFocus() {
      const viewportCenter = window.innerHeight * 0.52;
      cards.forEach((card) => {
        if (card.classList.contains('is-hidden-by-filter')) return;
        const rect = card.getBoundingClientRect();
        const cardCenter = rect.top + rect.height / 2;
        const distance = Math.abs(cardCenter - viewportCenter);
        const focus = Math.max(0, 1 - distance / (window.innerHeight * 0.55));
        card.classList.toggle('is-scroll-focus', focus > 0.72);
        card.style.setProperty('--repo-scroll-lift', `${(focus * -5).toFixed(2)}px`);
        card.style.setProperty('--cover-shift', `${(focus * -8).toFixed(2)}px`);
      });
    }

    updateScrollFocus();
    window.addEventListener('scroll', updateScrollFocus, { passive: true });
    window.addEventListener('resize', updateScrollFocus, { passive: true });
  })();

</script>

  <script is:inline>
    // ---------------------------
    // Feather icons -> inline SVG
    // ---------------------------
    function renderIcons() {
      if (window.feather && typeof window.feather.replace === "function") {
        window.feather.replace({ "stroke-width": 2, width: 20, height: 20 });
      }
    }

    // ---------------------------
    // Arcade particles (canvas)
    // ---------------------------
    const canvas = document.getElementById("arcadeCanvas");
    const ctx = canvas && canvas.getContext ? canvas.getContext("2d") : null;

    const colors = ["#00ff00", "#ff00ff", "#00ffff", "#ffff00"];
    const particles = [];
    const particleCount = 140;

    function resizeCanvas() {
      if (!canvas || !ctx) return;

      const dpr = window.devicePixelRatio || 1;
      canvas.width = Math.floor(window.innerWidth * dpr);
      canvas.height = Math.floor(window.innerHeight * dpr);
      canvas.style.width = window.innerWidth + "px";
      canvas.style.height = window.innerHeight + "px";

      // Reset transform and scale to DPR
      ctx.setTransform(1, 0, 0, 1, 0, 0);
      ctx.scale(dpr, dpr);
    }

    function rand(min, max) {
      return Math.random() * (max - min) + min;
    }

    class Particle {
      constructor() {
        this.x = rand(0, window.innerWidth);
        this.y = rand(0, window.innerHeight);
        this.size = rand(1, 3);
        this.speedX = rand(-1.2, 1.2);
        this.speedY = rand(-1.2, 1.2);
        this.color = colors[Math.floor(Math.random() * colors.length)];
        this.twinkle = rand(0.2, 1);
      }

      update() {
        this.x += this.speedX;
        this.y += this.speedY;

        // Bounce
        if (this.x < 0 || this.x > window.innerWidth) this.speedX *= -1;
        if (this.y < 0 || this.y > window.innerHeight) this.speedY *= -1;

        // Subtle twinkle
        this.twinkle += rand(-0.02, 0.02);
        if (this.twinkle < 0.25) this.twinkle = 0.25;
        if (this.twinkle > 1) this.twinkle = 1;
      }

      draw() {
        if (!ctx) return;

        // Pixel square
        ctx.fillStyle = this.color;
        ctx.globalAlpha = this.twinkle;
        ctx.fillRect(this.x, this.y, this.size, this.size);

        // Glow pass (soft)
        ctx.globalAlpha = this.twinkle * 0.45;
        ctx.shadowBlur = 10;
        ctx.shadowColor = this.color;
        ctx.fillRect(this.x, this.y, this.size, this.size);
        ctx.shadowBlur = 0;
        ctx.globalAlpha = 1;
      }
    }

    function initParticles() {
      particles.length = 0;
      for (let i = 0; i < particleCount; i++) particles.push(new Particle());
    }

    function animate() {
      if (!ctx) return;

      // Trail
      ctx.fillStyle = "rgba(10, 10, 10, 0.12)";
      ctx.fillRect(0, 0, window.innerWidth, window.innerHeight);

      particles.forEach((p) => {
        p.update();
        p.draw();
      });

      requestAnimationFrame(animate);
    }

    // ---------------------------
    // Reveal on scroll (UX)
    // ---------------------------
    function initReveal() {
      const items = document.querySelectorAll("[data-reveal]");
      if (!("IntersectionObserver" in window) || items.length === 0) {
        items.forEach((el) => el.classList.add("is-visible"));
        return;
      }

      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add("is-visible");
              io.unobserve(e.target);
            }
          });
        },
        { root: null, threshold: 0.12 }
      );

      items.forEach((el) => io.observe(el));
    }

    // ---------------------------
    // Smooth scroll + scroll spy
    // ---------------------------
    function initNavUX() {
      // Smooth scroll
      document.querySelectorAll('a[href^="#"]').forEach((a) => {
        a.addEventListener("click", (e) => {
          const href = a.getAttribute("href");
          if (!href) return;
          const target = document.querySelector(href);
          if (!target) return;
          e.preventDefault();
          target.scrollIntoView({ behavior: "smooth", block: "start" });
        });
      });

      // Scroll spy (keeps UI, improves UX)
      const links = Array.from(document.querySelectorAll(".nav-link"));
      const sections = links
        .map((l) => document.querySelector(l.getAttribute("href")))
        .filter(Boolean);

      function setActive(id) {
        links.forEach((l) => {
          const isActive = l.getAttribute("href") === "#" + id;
          l.classList.toggle("active", isActive);
        });
      }

      function onScroll() {
        let current = null;
        const y = window.scrollY + 140;
        sections.forEach((sec) => {
          const top = sec.offsetTop;
          const bottom = top + sec.offsetHeight;
          if (y >= top && y < bottom) current = sec;
        });
        if (current && current.id) setActive(current.id);
      }

      window.addEventListener("scroll", onScroll, { passive: true });
      onScroll();
    }

    // ---------------------------
    // Micro-interactions (sound/theme/github)
    // ---------------------------
    function initButtons() {
      const githubBtn = document.getElementById("githubBtn");
      const themeBtn = document.getElementById("themeBtn");
      const soundBtn = document.getElementById("soundBtn");

      // GitHub
      if (githubBtn) {
        githubBtn.addEventListener("click", () => {
          window.open("https://github.com/Cde571", "_blank", "noreferrer");
        });
      }

      // Tiny arcade click (no asset)
      let soundEnabled = true;
      function clickBeep() {
        if (!soundEnabled) return;
        try {
          const AudioCtx = window.AudioContext || window.webkitAudioContext;
          const ac = new AudioCtx();
          const o = ac.createOscillator();
          const g = ac.createGain();
          o.type = "square";
          o.frequency.value = 520;
          g.gain.value = 0.02;
          o.connect(g);
          g.connect(ac.destination);
          o.start();
          o.stop(ac.currentTime + 0.05);
          setTimeout(() => ac.close(), 100);
        } catch (_) {}
      }

      // Sound toggle
      if (soundBtn) {
        soundBtn.addEventListener("click", () => {
          soundEnabled = !soundEnabled;
          clickBeep();
          soundBtn.classList.toggle("is-off", !soundEnabled);
        });
      }

      // Theme toggle (keeps UI; just swaps variables slightly)
      let dark = true;
      function applyTheme() {
        document.documentElement.dataset.theme = dark ? "dark" : "light";
        // swap icon
        if (themeBtn) {
          themeBtn.innerHTML = dark
            ? '<i data-feather="sun" aria-hidden="true"></i>'
            : '<i data-feather="moon" aria-hidden="true"></i>';
          renderIcons();
        }
      }
      if (themeBtn) {
        themeBtn.addEventListener("click", () => {
          dark = !dark;
          clickBeep();
          applyTheme();
        });
      }
      applyTheme();

      // Connect / Resume / Contact
      ["connectBtn", "resumeBtn", "contactBtn"].forEach((id) => {
        const el = document.getElementById(id);
        if (el) el.addEventListener("click", clickBeep);
      });

      const resumeBtn = document.getElementById("resumeBtn");
      if (resumeBtn) {
        resumeBtn.addEventListener("click", () => {
          window.setTimeout(() => window.open("/resume.pdf", "_blank", "noreferrer"), 80);
        });
      }
    }

    // ---------------------------
    // Boot
    // ---------------------------
    document.addEventListener("DOMContentLoaded", () => {
      renderIcons();
      resizeCanvas();
      initParticles();
      animate();
      initReveal();
      initNavUX();
      initButtons();
    });

    window.addEventListener("resize", () => {
      resizeCanvas();
      // keep particles within bounds after resize
      particles.forEach((p) => {
        p.x = Math.min(Math.max(p.x, 0), window.innerWidth);
        p.y = Math.min(Math.max(p.y, 0), window.innerHeight);
      });
    });
  

  // ==========================================
  // PROJECTS: filtros, card-click y scroll effects
  // ==========================================
  (function () {
